# Public app URL used in NOWPayments redirects and webhook callback URLs.
NEXT_PUBLIC_APP_URL=https://lead-enrichment.prin7r.com

# Reown / WalletConnect Cloud project ID (Wave 3 — direct-wallet fallback).
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Merchant settlement wallets — fresh test wallets, not production treasury wallets.
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=

# NOWPayments — primary rail. Hosted invoice + IPN webhook.
# Without these the landing's Pricing CTAs return HTTP 503 missing_env (acceptable per playbook).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# Onramper card-to-stablecoin widget and optional webhook (Wave 3).
NEXT_PUBLIC_ONRAMPER_API_KEY=
ONRAMPER_WEBHOOK_SECRET=

# Mercuryo on-ramp widget (Wave 3).
NEXT_PUBLIC_MERCURYO_WIDGET_ID=
NEXT_PUBLIC_MERCURYO_ENV=sandbox
MERCURYO_WEBHOOK_SECRET=

# Plisio direct stablecoin invoices (backup rail).
PLISIO_API_KEY=

# Cryptomus / Heleket — listed for parity with payments-prototypes; do NOT activate in Wave 2.
CRYPTOMUS_MERCHANT_UUID=
CRYPTOMUS_PAYMENT_API_KEY=
HELEKET_MERCHANT_UUID=
HELEKET_PAYMENT_API_KEY=

# API service runtime — defaults shown.
PORT=8080
NODE_ENV=production
